# User configuration files (contain cluster-specific data)
*/config/user-config
*/config/pko-test-config

# Runtime state files (auto-generated by scripts)
*/config/runtime-state

# Example files ARE tracked in git
!*/config/*.example

# Log files
*/logs/*
!*/logs/.gitkeep

# Backup files
*/backups/*
!*/backups/.gitkeep

# macOS
.DS_Store

# Runtime files
*.log
login.sh

# Cluster-specific manifests (generated at runtime)
*-clusterpackage.yaml
*/clusterpackage.yaml

# Local scratch/working directories (contain cluster-specific, user-specific content)
scratch/
*/scratch/
